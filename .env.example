# AI Employee — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Gmail SMTP (for sending emails via email-mcp)
# Get app password: https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER=your@gmail.com
GMAIL_SMTP_APP_PASSWORD=your_16_char_app_password

# Vault path
VAULT_PATH=D:/Batch82/Gold/AI_Employee_Vault

# Safety: set to "true" during development to prevent real actions
DRY_RUN=true
